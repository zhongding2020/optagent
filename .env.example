# DeepSeek LLM (default provider)
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Optional: alternative providers (override config.yaml to use these)
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

# Embedding model (OpenAI compatible, for KB vector search)
OPENAI_API_KEY=sk-your-openai-embedding-key-here
